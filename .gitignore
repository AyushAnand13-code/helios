# ── Python ───────────────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# ── dbt ──────────────────────────────────────────────
target/
dbt_packages/
logs/
dbt/target/
dbt/dbt_packages/
dbt/logs/
# Anonymous-usage UUID dbt writes per machine; machine-local, never commit.
.user.yml

# ── Secrets & credentials — NEVER commit ─────────────
.env
.env.*
*.local
**/service-account*.json
**/*-sa.json
**/credentials*.json
gcp-key*.json
# Streamlit secrets (API keys) — local only, never commit:
.streamlit/secrets.toml
# (Helios uses ADC / Workload Identity Federation — keep key files out of git entirely.)

# ── Eval run outputs (keep the dir, ignore contents) ──
eval/benchmark_results/*
!eval/benchmark_results/.gitkeep

# ── Autonomous-run output (generated Decision Briefs; CI uploads them as artifacts) ──
briefs/

# ── Diagnosis memory store (local report-mcp state; persist out-of-band in prod) ──
# Root-anchored so it does NOT match the helios/memory/ source package.
/memory/

# ── OS / editor ──────────────────────────────────────
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
